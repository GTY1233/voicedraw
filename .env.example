# 复制为 .env 并填入你自己的密钥（.env 已被 .gitignore 忽略，绝不提交）

# 七牛云 AI 大模型推理（OpenAI 兼容）—— 对话理解 / 文生图 / 局部重绘 / 视觉看图确认
QINIU_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
QINIU_BASE_URL=https://api.qnaigc.com/v1
NLU_MODEL=deepseek-v3
IMAGE_MODEL=gemini-2.5-flash-image
IMAGE_MODEL_HQ=gemini-3.0-pro-image-preview
VISION_MODEL=qwen-vl-max-2025-01-25

# 阿里云百炼 DashScope —— 实时流式语音识别(ASR)
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DASHSCOPE_ASR_MODEL=paraformer-realtime-v2

# 备选图像 provider（可留空）
SILICONFLOW_API_KEY=
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1

# 后端代理端口（可选，默认 8787）
PORT=8787
